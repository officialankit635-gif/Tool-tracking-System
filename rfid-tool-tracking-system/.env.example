# ============================================================
# RFID Tool Tracking System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Backend / API Server ---
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (Railway sets this automatically)
PORT=8080

# Node environment
NODE_ENV=production

# Comma-separated list of allowed frontend origins (production only)
# Example: https://rfid-tracker-production.up.railway.app
ALLOWED_ORIGINS=

# --- Frontend (set before building — baked in by Vite at build time) ---
# Full URL to the deployed backend API (no trailing slash)
# Example: https://rfid-api-production.up.railway.app
VITE_API_URL=http://localhost:8080
